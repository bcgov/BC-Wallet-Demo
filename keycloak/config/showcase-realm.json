{
  "realm": "showcase",
  "enabled": true,
  "displayName": "BC Wallet Showcase",
  "sslRequired": "none",
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "bruteForceProtected": true,
  "ssoSessionIdleTimeout": 1800,
  "accessTokenLifespan": 300,
  "clients": [
    {
      "clientId": "showcase-admin",
      "name": "BC Wallet Showcase Admin",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:3000/*", "http://localhost:3000/digital-trust/showcase/admin/callback"],
      "webOrigins": ["http://localhost:3000"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Administrator role for the showcase admin portal"
      }
    ]
  },
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@example.com",
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["admin"]
    }
  ]
}
