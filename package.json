{
  "name": "bc-wallet-demo",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "BC Wallet - Verifiable Credential Demo",
  "repository": {
    "url": "https://github.com/bcgov/bc-wallet-demo",
    "type": "git"
  },
  "workspaces": [
    "frontend",
    "server"
  ],
  "scripts": {
    "check-types": "tsc --noEmit",
    "prettier": "prettier '**/*.+(js|json|ts|md|yml|yaml)'",
    "lint": "eslint --ignore-path .gitignore .",
    "lint:fix": "eslint --ignore-path .gitignore . --fix",
    "format": "yarn prettier --write",
    "prepare": "husky install",
    "frontend:start": "yarn workspace frontend start",
    "frontend:build": "yarn workspace frontend build",
    "server:dev": "yarn workspace server dev",
    "server:build": "yarn workspace server build",
    "dev": "concurrently -n 'frontend,server ' -c 'green.bold,red.bold' 'yarn frontend:start' 'yarn server:dev'",
    "test": "yarn run cypress open",
    "build": "yarn workspace frontend build && yarn workspace server build",
    "cy:open": "cypress open",
    "cy:run": "cypress run"
  },
  "devDependencies": {
    "concurrently": "^7.0.0",
    "cypress": "^13",
    "eslint-config-prettier": "^8.3.0",
    "eslint-import-resolver-typescript": "^2.7.0",
    "eslint-plugin-cypress": "^2.12.1",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-prettier": "^4.0.0",
    "husky": "^7.0.1",
    "prettier": "^2.6.1"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
