{
  "name": "bc-wallet-demo",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "BC Wallet - Verifiable Credential Demo",
  "repository": {
    "url": "https://github.com/bcgov/bc-wallet-demo",
    "type": "git"
  },
  "workspaces": [
    "frontend",
    "server"
  ],
  "scripts": {
    "check-types": "yarn workspace frontend exec tsc --noEmit -p tsconfig.json && yarn workspace server exec tsc --noEmit -p tsconfig.json",
    "prettier": "prettier '**/*.+(js|json|ts|md|yml|yaml)'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "yarn prettier --write",
    "prepare": "husky install",
    "frontend:start": "yarn workspace frontend start",
    "frontend:build": "yarn workspace frontend build",
    "server:dev": "yarn workspace server dev",
    "server:build": "yarn workspace server build",
    "dev": "concurrently -n 'frontend,server ' -c 'green.bold,red.bold' 'yarn frontend:start' 'yarn server:dev'",
    "test": "yarn run cypress open",
    "build": "yarn workspace frontend build && yarn workspace server build",
    "cy:open": "cypress open",
    "cy:run": "cypress run"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.22.0",
    "@types/node": "^25.6.0",
    "concurrently": "^7.0.0",
    "cypress": "^13",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.2",
    "eslint-plugin-cypress": "^6.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.0.0",
    "husky": "^7.0.1",
    "prettier": "^3.5.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.2"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "yarn@1.22.22",
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "heroicons": "^2.2.0"
  }
}
